#!/bin/sh
#|-*- mode:lisp -*-|#
#|
exec ros -Q -- $0 "$@"
|#
(progn ;; init forms
  (ros:ensure-asdf)
  #+quicklisp (ql:quickload :cl-llama-chat :silent t))

(defpackage :ros.script.cl-llama-chat
  (:use :cl))
(in-package :ros.script.cl-llama-chat)

(defun main (&rest argv)
  (declare (ignore argv))
  (cl-llama-chat:main))
