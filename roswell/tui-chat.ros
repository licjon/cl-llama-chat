#!/bin/sh
#|-*- mode:lisp -*-|#
#|
exec ros -Q -- $0 "$@"
|#
(progn ;; init forms
  (ros:ensure-asdf)
  #+quicklisp (ql:quickload :tui-chat :silent t))

(defpackage :ros.script.tui-chat
  (:use :cl))
(in-package :ros.script.tui-chat)

(defun main (&rest argv)
  (declare (ignore argv))
  (tui-chat:main))
